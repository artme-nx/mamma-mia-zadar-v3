{
  "$schema": "https://design-tokens.org/schema.json",
  "primitive": {
    "color": {
      "paper": {
        "100": { "$value": "#FBF3E6", "$type": "color" },
        "200": { "$value": "#F3E7D2", "$type": "color" },
        "300": { "$value": "#E8D5B2", "$type": "color" }
      },
      "ink": {
        "900": { "$value": "#2A2018", "$type": "color" },
        "700": { "$value": "#5B4C3E", "$type": "color" },
        "500": { "$value": "#8E7E6B", "$type": "color" }
      },
      "tomato": {
        "500": { "$value": "#C1432A", "$type": "color" },
        "700": { "$value": "#9A331F", "$type": "color" },
        "900": { "$value": "#4A1D12", "$type": "color" }
      },
      "basil": {
        "500": { "$value": "#54704A", "$type": "color" },
        "700": { "$value": "#3B5033", "$type": "color" }
      }
    },
    "font": {
      "display": { "$value": "var(--font-instrument-serif), 'Instrument Serif', Georgia, serif", "$type": "fontFamily" },
      "sans": { "$value": "var(--font-work-sans), system-ui, sans-serif", "$type": "fontFamily" }
    },
    "motion": {
      "duration": {
        "micro": { "$value": "180ms", "$type": "duration" },
        "base": { "$value": "320ms", "$type": "duration" },
        "reveal": { "$value": "1.1s", "$type": "duration" },
        "cine": { "$value": "1.8s", "$type": "duration" }
      },
      "ease": {
        "out-expo": { "$value": "cubic-bezier(0.16, 1, 0.3, 1)", "$type": "cubicBezier" },
        "cine": { "$value": "cubic-bezier(0.65, 0, 0.35, 1)", "$type": "cubicBezier" }
      }
    },
    "tracking": {
      "display": { "$value": "-0.01em", "$type": "dimension" },
      "label": { "$value": "0.26em", "$type": "dimension" }
    }
  },
  "semantic": {
    "background": { "$value": "{primitive.color.paper.100}", "$type": "color" },
    "foreground": { "$value": "{primitive.color.ink.900}", "$type": "color" },
    "card": { "$value": "{primitive.color.paper.200}", "$type": "color" },
    "card-foreground": { "$value": "{primitive.color.ink.900}", "$type": "color" },
    "muted": { "$value": "{primitive.color.paper.200}", "$type": "color" },
    "muted-foreground": { "$value": "{primitive.color.ink.700}", "$type": "color" },
    "accent": { "$value": "{primitive.color.paper.300}", "$type": "color" },
    "accent-foreground": { "$value": "{primitive.color.ink.900}", "$type": "color" },
    "border": { "$value": "{primitive.color.paper.300}", "$type": "color" },
    "ring": { "$value": "{primitive.color.tomato.500}", "$type": "color" },
    "radius": { "$value": "0.9rem", "$type": "dimension" },
    "brand": { "$value": "{primitive.color.tomato.500}", "$type": "color" },
    "brand-dim": { "$value": "{primitive.color.tomato.900}", "$type": "color" },
    "basil": { "$value": "{primitive.color.basil.500}", "$type": "color" },
    "basil-dim": { "$value": "{primitive.color.basil.700}", "$type": "color" },
    "surface-line": { "$value": "{primitive.color.paper.300}", "$type": "color" },
    "type-display": { "$value": "{primitive.font.display}", "$type": "fontFamily" },
    "type-body": { "$value": "{primitive.font.sans}", "$type": "fontFamily" },
    "ease-reveal": { "$value": "{primitive.motion.ease.out-expo}", "$type": "cubicBezier" },
    "ease-cine": { "$value": "{primitive.motion.ease.cine}", "$type": "cubicBezier" },
    "duration-micro": { "$value": "{primitive.motion.duration.micro}", "$type": "duration" },
    "duration-base": { "$value": "{primitive.motion.duration.base}", "$type": "duration" },
    "duration-reveal": { "$value": "{primitive.motion.duration.reveal}", "$type": "duration" },
    "tracking-display": { "$value": "{primitive.tracking.display}", "$type": "dimension" },
    "tracking-label": { "$value": "{primitive.tracking.label}", "$type": "dimension" }
  },
  "component": {
    "hero": {
      "title-size": { "$value": "clamp(2.6rem, 7vw, 5.8rem)", "$type": "dimension" },
      "title-leading": { "$value": "1.03", "$type": "number" },
      "glow": {
        "$value": "radial-gradient(ellipse 70% 50% at 50% 100%, rgba(193, 67, 42, 0.28), rgba(74, 29, 18, 0.12) 45%, transparent 72%)",
        "$type": "gradient"
      },
      "vignette": {
        "$value": "linear-gradient(to top, rgba(20, 13, 8, 0.94) 0%, rgba(20, 13, 8, 0.32) 45%, rgba(20, 13, 8, 0.5) 100%)",
        "$type": "gradient"
      }
    },
    "button": {
      "primary-bg": { "$value": "{primitive.color.tomato.500}", "$type": "color" },
      "primary-fg": { "$value": "{primitive.color.paper.100}", "$type": "color" },
      "primary-hover-bg": { "$value": "{primitive.color.tomato.700}", "$type": "color" },
      "ghost-border": { "$value": "rgba(42, 32, 24, 0.28)", "$type": "color" },
      "ghost-hover-border": { "$value": "{primitive.color.tomato.500}", "$type": "color" }
    }
  }
}
